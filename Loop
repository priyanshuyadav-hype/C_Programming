Que9.Find the HCF of two numbers using loop.
#include<stdio.h>
void main()
{
	int a,b,i=1,min,hcf;
	printf("Enter two numbers.\n");
	scanf("%d%d",&a,&b);
    if(a>b)
      min=b;
    else
      min=a;
	//Loop
	while(i<=min)
	{
		if(a%i==0 && b%i==0)
		{
			hcf=i;
		}
		i++;
	}
	printf("HCF = %d",hcf);
}

Que10.Write a programme to find the LCM of two numbers using loop.
#include<stdio.h>
void main()
{
	int a,b,i=1,min,hcf,lcm;
	printf("Enter two numbers.\n");
	scanf("%d%d",&a,&b);
    if(a>b)
      min=b;
    else
      min=a;
	//Loop
	while(i<=min)
	{
		if(a%i==0 && b%i==0)
		{
			hcf=i;
		}
		i++;
	}
	lcm=(a*b)/hcf;
	printf("LCM = %d",lcm);
}

Que11.Generate the fibbonacci series up to n terms.
#include<stdio.h>
void main()
{
	int i=1,n,a=0,b=1,next;
	printf("Enter ending of series.\n");
	scanf("%d",&n);
	//while loop
	while(i<=n)
	{
		printf("%d\t",a);
		next=a+b;
		a=b;
		b=next;
		i++;
	}
}

